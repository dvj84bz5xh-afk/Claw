<package xmlns="http://www.idpf.org/2007/opf" unique-identifier="ISBN-9781804296929" version="2.0">
  <metadata xmlns:dc="http://purl.org/dc/elements/1.1/" xmlns:opf="http://www.idpf.org/2007/opf">
    <dc:title>Scam</dc:title>
    <dc:creator>Ivan Franceschini</dc:creator>
    <dc:identifier id="ISBN-9781804296929" opf:scheme="URI">ISBN-9781804296929</dc:identifier>
    <dc:publisher>Verso Books</dc:publisher>
