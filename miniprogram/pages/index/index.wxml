<!--pages/index/index.wxml-->
<view class="container">
  <view class="header">
    <text class="title">专家AI助手</text>
    <text class="subtitle">选择专家,开始对话</text>
  </view>

  <view class="assistant-list">
    <view 
      class="assistant-card" 
      wx:for="{{assistants}}" 
      wx:key="id"
      bindtap="startChat"
      data-assistant="{{item}}"
    >
      <view class="assistant-avatar">
        <image src="{{item.avatar}}" mode="aspectFit"></image>
      </view>
      <view class="assistant-info">
        <view class="assistant-name">{{item.name}}</view>
        <view class="assistant-desc">{{item.description}}</view>
      </view>
      <view class="arrow">›</view>
    </view>
  </view>

  <view class="quick-actions">
    <view class="action-card" bindtap="goToAssistants">
      <view class="action-icon">⚙️</view>
      <view class="action-text">管理助手</view>
    </view>
  </view>
</view>
