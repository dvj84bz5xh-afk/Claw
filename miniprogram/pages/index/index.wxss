/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 30rpx;
}

.header {
  text-align: center;
  padding: 60rpx 0 40rpx;
  color: #fff;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  opacity: 0.9;
  display: block;
}

.assistant-list {
  padding-bottom: 20rpx;
}

.assistant-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s;
}

.assistant-card:active {
  transform: scale(0.98);
}

.assistant-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.assistant-avatar image {
  width: 60rpx;
  height: 60rpx;
}

.assistant-info {
  flex: 1;
}

.assistant-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.assistant-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.arrow {
  font-size: 48rpx;
  color: #ccc;
  margin-left: 16rpx;
}

.quick-actions {
  margin-top: 40rpx;
  display: flex;
  gap: 20rpx;
}

.action-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  color: #fff;
  backdrop-filter: blur(10rpx);
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 26rpx;
}
