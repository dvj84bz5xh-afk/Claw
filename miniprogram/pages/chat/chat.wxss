/* pages/chat/chat.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

/* 顶部助手信息 */
.chat-header {
  background: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #eee;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.assistant-info {
  display: flex;
  align-items: center;
}

.chat-header .assistant-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.avatar-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.assistant-details {
  display: flex;
  flex-direction: column;
}

.assistant-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.assistant-status {
  font-size: 22rpx;
  color: #52c41a;
}

.header-actions {
  display: flex;
  align-items: center;
}

.action-btn {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
}

/* 聊天消息区域 */
.chat-messages {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

.message-list {
  min-height: 100%;
}

.message {
  display: flex;
  margin-bottom: 40rpx;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.message-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 24rpx;
}

.user-avatar {
  background: #1890ff;
}

.assistant-avatar {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.user-message {
  flex-direction: row-reverse;
}

.user-message .message-avatar {
  margin-left: 20rpx;
}

.assistant-message .message-avatar {
  margin-right: 20rpx;
}

.message-content {
  max-width: 70%;
}

.message-text {
  padding: 24rpx 28rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.user-message .message-text {
  background: #1890ff;
  color: #fff;
  border-bottom-right-radius: 4rpx;
}

.assistant-message .message-text {
  background: #fff;
  color: #333;
  border-bottom-left-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.message-time {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
  padding: 0 8rpx;
}

.user-message .message-time {
  text-align: right;
}

/* 加载动画 */
.loading-message {
  opacity: 0.7;
}

.typing-indicator {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: #999;
  border-radius: 50%;
  animation: typing 1.4s infinite;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%, 60%, 100% {
    transform: translateY(0);
  }
  30% {
    transform: translateY(-10rpx);
  }
}

/* 输入区域 */
.chat-input-area {
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid #eee;
}

.input-container {
  display: flex;
  align-items: flex-end;
  gap: 20rpx;
}

.input-box {
  flex: 1;
  min-height: 80rpx;
  max-height: 200rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.send-btn {
  width: 120rpx;
  height: 80rpx;
  background: #d9d9d9;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  transition: all 0.3s;
  flex-shrink: 0;
}

.send-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.send-btn:active {
  transform: scale(0.95);
}
